# PLAIN_CHAT_SECRET - required for chat authentication (app/api/chat-auth).
# Generate this from the Chat settings page in the Plain dashboard
# (help.plain.com/article/chat-authentication). Used server-side only to
# HMAC-SHA256 a visitor's email before it's passed to Plain.init() as
# customerDetails.emailHash - never expose this value to the client.
PLAIN_CHAT_SECRET=

# The Plain+GitHub ticket-creation workflow (which previously needed
# PLAIN_API_KEY, GITHUB_TOKEN, GITHUB_REPO, GITHUB_WEBHOOK_SECRET,
# PLAIN_WEBHOOK_SECRET) has been moved to archive/ and is not part of
# the deployed app. See archive/README.md before reviving it.
